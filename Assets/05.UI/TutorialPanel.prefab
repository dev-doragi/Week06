    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC804\uD22C\uB97C \uB9C8\uCE58\uBA74 \uACF5\uC131\uBCD1\uAE30\uB294
      \uB2E4\uC74C \uC2A4\uD14C\uC774\uC9C0\uC5D0\uC11C\uB3C4 \uADF8\uB300\uB85C
      \uC720\uC9C0\uB429\uB2C8\uB2E4. "
