  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC548\uC815\uC801\uC778 \uBCF4\uAE09\uC744 \uC704\uD574 \uC0DD\uC131\uAE30\uB97C
      \uBC30\uCE58\uD574 \uBD05\uC2DC\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 405224111575878242}
    RequiredPartKeys: 0a0000000b0000000c0000000d000000
