--- !u!114 &213241987242629725
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8161377643539104782}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6039eb702d31fae489d282ef3a879a67, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  _isDontDestroyOnLoad: 0
  _dialogPanel: {fileID: 1698197600764794956}
  _nameText: {fileID: 8094103395032301937}
  _dialogText: {fileID: 32396568195685859}
  _portraitImage: {fileID: 7975207625282867106}
  _highlighter: {fileID: 2375346784971493985}
  _clickButton: {fileID: 4439620085233567736}
  _postPanel: {fileID: 5926704351903602396}
  _placementProgressPanel: {fileID: 3555276280400176784}
  _placementProgressText: {fileID: 2119152732316717486}
  _typingSpeed: 0.025
  _cameraResetDuration: 1
  _steps:
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC801\uB4E4\uC774 \uC544\uAD70 \uCF54\uC5B4\uB97C \uB178\uB9AC\uACE0
      \uACF5\uACA9\uD574 \uC635\uB2C8\uB2E4. \uC950 \uBD80\uB300\uB97C \uBC30\uCE58\uD558\uC5EC
      \uCF54\uC5B4\uAC00 \uD30C\uAD34\uB418\uC9C0 \uC54A\uB3C4\uB85D \uBC29\uC5B4\uD574\uC57C
      \uD569\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 0}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uD720 \uC2A4\uD06C\uB864\uC744 \uC774\uC6A9\uD574 \uC804\uC7A5\uC744
      \uD655\uB300\uD558\uACE0, \uB9C8\uC6B0\uC2A4 \uC6B0\uD074\uB9AD \uB4DC\uB798\uADF8\uB85C
      \uD654\uBA74\uC744 \uC774\uB3D9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 0}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uD55C \uBC88 \uC790\uC720\uB86D\uAC8C \uCE74\uBA54\uB77C\uB97C \uC774\uB3D9\uD574\uBCF4\uC138\uC694.
      <br>\n(\uC2A4\uD06C\uB864: \uD655\uB300 / \uC6B0\uD074\uB9AD \uB4DC\uB798\uADF8:
      \uC774\uB3D9)"
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 0}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 1
    RequiredAmount: 4
    AutoAdvanceDelay: 0
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC88C\uCE21 \uC0C1\uC810\uC5D0\uC11C \uD655\uBCF4\uD55C \uD3EC\uB85C
      \uC950\uB4E4\uC744 \uC18C\uBAA8\uD558\uC5EC \uC720\uB2DB\uC744 \uACF5\uC131\uBCD1\uAE30
      \uC704\uC5D0 \uBC30\uCE58\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD30C\uCE20\uB9C8\uB2E4
      \uC5ED\uD560\uC774 \uB2E4\uB985\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 1535280458346550041}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC720\uB2DB\uC740 \uACF5\uACA9, \uBC29\uC5B4, \uC9C0\uC6D0\uC758 \uC138
      \uAC00\uC9C0 \uC5ED\uD560\uC744 \uC218\uD589\uD569\uB2C8\uB2E4. \uBC29\uC5B4
      \uC720\uB2DB\uC740 \uCCB4\uB825\uC774 \uB192\uACE0 \uC801\uACFC \uCDA9\uB3CC
      \uC2DC \uB300\uBBF8\uC9C0\uB97C \uC8FC\uBBC0\uB85C \uCD5C\uC804\uBC29\uC5D0
      \uBC30\uCE58\uD558\uB294 \uAC83\uC774 \uC720\uB9AC\uD569\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 2678590677395719300}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC801\uC758 \uACF5\uACA9\uC744 \uB9C9\uAE30 \uC704\uD574 \uBC29\uC5B4
      \uC720\uB2DB\uC744 \uC124\uCE58\uD574 \uBCF4\uC138\uC694."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 255604084205943565}
    RequiredPartKeys: 00000000
    RequiredGroup: 1
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 2
    RequiredAmount: 5
    AutoAdvanceDelay: 0
    PlacementLabel: "\uBC29\uC5B4 \uC720\uB2DB \uC124\uCE58\uD558\uAE30"
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC801\uC758 \uACF5\uACA9\uC744 \uB9C9\uC558\uC9C0\uB9CC, \uC774\uB294
      \uC77C\uC2DC\uC801\uC778 \uC218\uB2E8\uC77C \uBFD0\uC785\uB2C8\uB2E4. \uC801\uC758
      \uCF54\uC5B4\uB97C \uD30C\uAD34\uD574\uC57C \uC804\uD22C\uC5D0\uC11C \uC2B9\uB9AC\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 7637483270051685808}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 1
    PortraitMoveOffset: -1000
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uACF5\uACA9 \uC720\uB2DB\uC740 \uD654\uB825 \uAC04\uC12D\uC744 \uB9C9\uAE30
      \uC704\uD574 \uC11C\uB85C \uBD99\uC5EC\uC11C \uBC30\uCE58\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 2678590677395719300}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
    AutoAdvanceDelay: 3
    PlacementLabel: 
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC774\uC81C \uACF5\uACA9 \uC720\uB2DB\uC744 \uC120\uD0DD\uD574 \uBCF4\uB4DC
      \uC704\uC5D0 \uC9C1\uC811 \uBC30\uCE58\uD574 \uBCF4\uC138\uC694."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 507113195504626307}
    RequiredPartKeys: 
    RequiredGroup: 2
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 2
    RequiredAmount: 3
    AutoAdvanceDelay: 0
    PlacementLabel: "\uACF5\uACA9 \uC720\uB2DB \uC124\uCE58\uD558\uAE30"
    MovePortraitLeft: 0
    PortraitMoveOffset: 150
    PortraitMoveDuration: 0.5
    PortraitTarget: {fileID: 0}
  - SpeakerName: "\uC950\uC2E0\uAD00\uCA29"
    Message: "\uC804\uD22C \uC911 \uC720\uB2DB\uB4E4\uC740 \uC790\uB3D9\uC73C\uB85C
      \uACF5\uACA9\uD558\uBA70, \uACF5\uACA9 \uC2DC\uB9C8\uB2E4 \uC950\uB97C \uC18C\uBAA8\uD569\uB2C8\uB2E4.
      \uC950\uAC00 \uC804\uBD80 \uC18C\uBAA8\uB418\uBA74 \uACF5\uACA9\uC744 \uD560
      \uC218 \uC5C6\uC73C\uBBC0\uB85C \uC0DD\uC131\uAE30\uB97C \uD1B5\uD574 \uC950\uB4E4\uC744
      \uC9C0\uC18D\uC801\uC73C\uB85C '\uC0DD\uC0B0'\uD574\uC57C \uD569\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: c0e411521309f804eaa2bbd84b5daf4f, type: 3}
    TargetUI: {fileID: 6491091956350355758}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 1
    MoveOffset: 300
    MoveDuration: 0.5
