  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6039eb702d31fae489d282ef3a879a67, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  _isDontDestroyOnLoad: 0
  _dialogPanel: {fileID: 201383907}
  _nameText: {fileID: 1243704641}
  _dialogText: {fileID: 45779402}
  _portraitImage: {fileID: 830944935}
  _highlighter: {fileID: 740014861}
  _clickButton: {fileID: 726527596}
  _postPanel: {fileID: 1596338307}
  _typingSpeed: 0.025
  _cameraResetDuration: 1
  _steps:
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC801\uB4E4\uC774 \uC544\uAD70 \uCF54\uC5B4\uB97C \uB178\uB9AC\uACE0
      \uACF5\uACA9\uD574 \uC635\uB2C8\uB2E4. \uC950 \uBD80\uB300\uB97C \uBC30\uCE58\uD558\uC5EC
      \uCF54\uC5B4\uAC00 \uD30C\uAD34\uB418\uC9C0 \uC54A\uB3C4\uB85D \uBC29\uC5B4\uD574\uC57C
      \uD569\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 0}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uB9C8\uC6B0\uC2A4 \uC6B0\uD074\uB9AD \uB4DC\uB798\uADF8\uB85C \uD654\uBA74\uC744
      \uC774\uB3D9\uD558\uACE0, \uD720 \uC2A4\uD06C\uB864\uC744 \uC774\uC6A9\uD574
      \uC804\uC7A5\uC744 \uD655\uB300\uD558\uAC70\uB098 \uCD95\uC18C\uD560 \uC218
      \uC788\uC2B5\uB2C8\uB2E4. \uCE74\uBA54\uB77C\uB97C \uC790\uC720\uB86D\uAC8C
      \uC6C0\uC9C1\uC5EC \uBCF4\uC138\uC694."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 0}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 1
    RequiredAmount: 3
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC88C\uCE21 \uC0C1\uC810\uC5D0\uC11C \uD655\uBCF4\uD55C \uD3EC\uB85C
      \uC950\uB4E4\uC744 \uC18C\uBAA8\uD558\uC5EC \uC720\uB2DB\uC744 \uACF5\uC131\uBCD1\uAE30
      \uC704\uC5D0 \uBC30\uCE58\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uD30C\uCE20\uB9C8\uB2E4
      \uC5ED\uD560\uC774 \uB2E4\uB985\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 2084308003}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC720\uB2DB\uC740 \uACF5\uACA9, \uBC29\uC5B4, \uC9C0\uC6D0\uC758 \uC138
      \uAC00\uC9C0 \uC5ED\uD560\uC744 \uC218\uD589\uD569\uB2C8\uB2E4. \uBC29\uC5B4
      \uC720\uB2DB\uC740 \uCCB4\uB825\uC774 \uB192\uACE0 \uC801\uACFC \uCDA9\uB3CC
      \uC2DC \uB300\uBBF8\uC9C0\uB97C \uC8FC\uBBC0\uB85C \uCD5C\uC804\uBC29\uC5D0
      \uBC30\uCE58\uD558\uB294 \uAC83\uC774 \uC720\uB9AC\uD569\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 1745759103}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC801\uC758 \uACF5\uACA9\uC744 \uB9C9\uAE30 \uC704\uD574 \uBC29\uC5B4
      \uD30C\uCE20\uB97C \uC124\uCE58\uD574 \uBCF4\uC138\uC694."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 979765336}
    RequiredPartKeys: 00000000
    RequiredGroup: 1
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 0
    BlockInput: 0
    Condition: 2
    RequiredAmount: 5
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC801\uC758 \uACF5\uACA9\uC744 \uB9C9\uC558\uC9C0\uB9CC, \uC774\uB294
      \uC77C\uC2DC\uC801\uC778 \uC218\uB2E8\uC77C \uBFD0\uC785\uB2C8\uB2E4. \uC801\uC758
      \uCF54\uC5B4\uB97C \uD30C\uAD34\uD574\uC57C \uC804\uD22C\uC5D0\uC11C \uC2B9\uB9AC\uD560
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 634853750}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uACF5\uACA9 \uC720\uB2DB\uC740 \uD654\uB825 \uAC04\uC12D\uC744 \uB9C9\uAE30
      \uC704\uD574 \uC11C\uB85C \uBD99\uC5EC\uC11C \uBC30\uCE58\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
    PortraitSprite: {fileID: 21300000, guid: 9d473c58fcd3ae043b98c91829e4767d, type: 3}
    TargetUI: {fileID: 1745759103}
    RequiredPartKeys: 
    RequiredGroup: 0
    MoveDialogUp: 0
    MoveOffset: 300
    MoveDuration: 0.5
    ShouldPause: 1
    BlockInput: 1
    Condition: 0
    RequiredAmount: 1
  - SpeakerName: "\uD29C\uD1A0\uB9AC\uC5BC\uC9F1"
    Message: "\uC774\uC81C \uACF5\uACA9 \uD30C\uCE20\uB97C \uC120\uD0DD\uD574 \uBCF4\uB4DC
